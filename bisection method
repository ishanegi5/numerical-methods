def f(x):
    return x**3 - x - 2   # Example function

a = 1
b = 2
tolerance = 0.0001

if f(a) * f(b) >= 0:
    print("Invalid interval")
else:
    while (b - a) / 2 > tolerance:
        c = (a + b) / 2
        if f(c) == 0:
            break
        elif f(a) * f(c) < 0:
            b = c
        else:
            a = c

    print("Root is:", c)
