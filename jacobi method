x1 = x2 = x3 = x4 = 0

for _ in range(5):  # number of iterations
    new_x1 = (6 + x2 - 2*x3) / 10
    new_x2 = (25 + x1 + x3 - 3*x4) / 11
    new_x3 = (-11 - 2*x1 + x2 + x4) / 10
    new_x4 = (15 - 3*x2 + x3) / 8

    x1 = new_x1
    x2 = new_x2
    x3 = new_x3
    x4 = new_x4

print("x1 =", x1)
print("x2 =", x2)
print("x3 =", x3)
print("x4 =", x4)
